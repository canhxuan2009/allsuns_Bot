# ─── THÔNG TIN DISCORD BOT (Bắt buộc) ───
DISCORD_TOKEN=your_bot_token_here
CLIENT_ID=your_bot_application_id_here

# ─── CẤU HÌNH MONGODB (Bắt buộc) ───
# Lấy Connection String từ MongoDB Atlas: https://cloud.mongodb.com
# Thay <username> và <password> bằng thông tin tài khoản database của bạn
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/allsuns_bot?retryWrites=true&w=majority

# Guild ID dùng khi deploy commands theo guild (deploy nhanh, chỉ dùng khi dev)
# Để trống nếu muốn deploy global (mất ~1 giờ để cập nhật)
GUILD_ID=your_server_id_here

# ─── CẤU HÌNH DỊCH TỰ ĐỘNG DONUTSMP (Tuỳ chọn) ───
# Sử dụng GEMINI_API_KEY ở mục Google AI Studio bên dưới để dịch
# ID kênh Discord chứa thông báo tiếng Anh cần dịch
TRANSLATE_SOURCE_CHANNEL=
# ID kênh Discord nơi bot gửi bản dịch tiếng Việt
TRANSLATE_TARGET_CHANNEL=
# ID của role Discord cần ping khi có bản dịch mới (để trống nếu không muốn ping)
TRANSLATE_PING_ROLE_ID=

# ─── CẤU HÌNH BOT ADMIN (Tuỳ chọn) ───
# Danh sách User ID của quản trị viên bot, phân cách bằng dấu phẩy
# Bot Admin có thể dùng các lệnh quản lý mà không cần quyền Discord tương ứng
BOT_ADMINS=

# ─── MAPPING CẤP ĐỘ VIP VỚI ROLE ID DISCORD (Tuỳ chọn) ───
# Định dạng chuỗi JSON: {"cấp_vip": "role_id_discord"}
# Ví dụ: {"1":"111222333444","2":"555666777888","10":"999000111222"}
VIP_ROLE_MAPPING={}

# ─── CẤU HÌNH GOOGLE AI STUDIO (GEMINI) ───
# Lấy API key miễn phí tại https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here
# Model Gemini sử dụng (Mặc định: gemini-2.5-flash)
GEMINI_MODEL=gemini-2.5-flash

# ─── CẤU HÌNH KIỂM DUYỆT HÌNH ẢNH TỰ ĐỘNG (Tuỳ chọn) ───
# ID role Member cần kiểm duyệt ảnh (bot chỉ quét ảnh của thành viên có role này)
MODERATION_MEMBER_ROLE_ID=
# User ID của chủ bot (nhận DM thông báo khi phát hiện scam)
MODERATION_OWNER_ID=
# ID role "Bị Giới Hạn" khi gửi ảnh scam
MODERATION_RESTRICTED_ROLE_ID=
# ID kênh xác minh con người
MODERATION_VERIFY_CHANNEL_ID=

# ─── CẤU HÌNH GIAO DỊCH TRUNG GIAN (Tuỳ chọn) ───
# ID Role của Midman — bot sẽ cấp quyền xem/quản lý ticket cho role này
ESCROW_MIDMAN_ROLE_ID=
# ID Category Discord nơi chứa các kênh ticket giao dịch
ESCROW_CATEGORY_ID=
# ID kênh Discord dùng để lưu trữ file HTML transcript và ảnh (ở Archive Server)
ESCROW_LOG_CHANNEL_ID=

# ── Cấu hình tách kênh lưu trữ Transcript (Mới - Tuỳ chọn) ──
# ID kênh chứa ảnh/tệp bằng chứng giao dịch
ESCROW_ATTACHMENT_CHANNEL_ID=
# ID kênh chứa file transcript HTML
ESCROW_HTML_CHANNEL_ID=
# ID kênh chứa Embed tóm tắt giao dịch (có đính kèm link tải HTML)
ESCROW_SUMMARY_CHANNEL_ID=

