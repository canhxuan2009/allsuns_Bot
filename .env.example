# ─── THÔNG TIN DISCORD BOT (Bắt buộc) ───
DISCORD_TOKEN=your_bot_token_here
CLIENT_ID=your_bot_application_id_here

# Guild ID dùng khi deploy commands theo guild (deploy nhanh, chỉ dùng khi dev)
# Để trống nếu muốn deploy global (mất ~1 giờ để cập nhật)
GUILD_ID=your_server_id_here

# ─── CẤU HÌNH DỊCH TỰ ĐỘNG DONUTSMP (Tuỳ chọn) ───
# Lấy API key miễn phí tại https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here
# ID kênh Discord chứa thông báo tiếng Anh cần dịch
TRANSLATE_SOURCE_CHANNEL=
# ID kênh Discord nơi bot gửi bản dịch tiếng Việt
TRANSLATE_TARGET_CHANNEL=
# ID của role Discord cần ping khi có bản dịch mới (để trống nếu không muốn ping)
TRANSLATE_PING_ROLE_ID=

# ─── CẤU HÌNH BOT ADMIN (Tuỳ chọn) ───
# Danh sách User ID của quản trị viên bot, phân cách bằng dấu phẩy
# Bot Admin có thể dùng các lệnh quản lý mà không cần quyền Discord tương ứng
BOT_ADMINS=

# ─── MAPPING CẤP ĐỘ VIP VỚI ROLE ID DISCORD (Tuỳ chọn) ───
# Định dạng chuỗi JSON: {"cấp_vip": "role_id_discord"}
# Ví dụ: {"1":"111222333444","2":"555666777888","10":"999000111222"}
VIP_ROLE_MAPPING={}

# ─── CẤU HÌNH GOOGLE AI STUDIO (GEMINI CHATBOT) ───
# Lấy API key miễn phí tại https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here
# ID kênh Discord dùng để trò chuyện trực tiếp với Gemini
GEMINI_CHANNEL_ID=your_gemini_chat_channel_id_here
# Model Gemini sử dụng (Mặc định: gemini-2.5-flash)
GEMINI_MODEL=gemini-2.5-flash
# System instruction (chỉ dẫn hệ thống) để thiết lập tính cách cho bot (Tùy chọn)
GEMINI_SYSTEM_INSTRUCTION=Bạn là một chatbot trợ lý thân thiện dành cho thành viên của Discord server Minecraft DonutSMP Việt Nam. Trả lời một cách ngắn gọn, tự nhiên và hữu ích.

